{
  "name": "today-daily-planner",
  "version": "2.0.21",
  "private": true,
  "description": "桌面浮窗日程与待办记事本",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ceceliahappyday/EveryTime.git"
  },
  "homepage": "https://github.com/ceceliahappyday/EveryTime",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win dir",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.local.todayDailyPlanner",
    "productName": "今日日程",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "recurrence-policy.js",
      "task-option-policy.js",
      "project-summary-policy.js",
      "app.js",
      "main.js",
      "preload.js",
      "assets/icons/**/*",
      "excel-runtime/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icons/app-icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "EveryTime-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "今日日程",
      "installerIcon": "assets/icons/app-icon.ico",
      "uninstallerIcon": "assets/icons/app-icon.ico",
      "include": "build/installer.nsh",
      "installerHeaderIcon": null
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ceceliahappyday",
        "repo": "EveryTime",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0"
  }
}
